generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === RETRO (Persistido no Neon) ===

model RetroSession {
  id             String       @id @default(cuid())
  roomId         String       @unique
  squad          String       @default("default")
  phase          String       @default("writing")
  revealedColumns String[]    @default([])
  createdAt      DateTime     @default(now())
  closedAt       DateTime?
  cards          RetroCard[]

  @@index([roomId])
  @@index([squad])
}

model RetroCard {
  id        String       @id @default(cuid())
  sessionId String
  session   RetroSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  column    CardColumn
  content   String
  author    String
  votes     Int          @default(0)
  completed Boolean      @default(false)
  migratedTo String?     // roomId da próxima retro para onde foi migrado
  createdAt DateTime     @default(now())

  @@index([sessionId, column])
}

enum CardColumn {
  WENT_WELL
  IMPROVE
  ACTION_ITEMS
}
